# Optional. Helps with higher OpenDota limits.
OPENDOTA_API_KEY=

# Optional. Enables STRATZ match timing fallback when OpenDota lacks purchase_log / first_purchase_time.
STRATZ_API_TOKEN=

# Optional. Durable remote replica for the SQLite match store (S3-compatible storage).
MATCH_STORE_S3_BUCKET=
MATCH_STORE_S3_KEY=
MATCH_STORE_S3_ENDPOINT_URL=
MATCH_STORE_S3_REGION=

# Optional settings
OPENDOTA_TIMEOUT=20
CACHE_TTL_HOURS=24
