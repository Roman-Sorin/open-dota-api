# Optional. Helps with higher OpenDota limits.
OPENDOTA_API_KEY=

# Optional. Enables STRATZ match timing fallback when OpenDota lacks purchase_log / first_purchase_time.
STRATZ_API_TOKEN=

# Optional. Durable external database for production cache persistence.
DATABASE_URL=

# Recommended. Durable Google Drive snapshot storage for production cache persistence.
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_SNAPSHOT_NAME=matches.sqlite3
GOOGLE_DRIVE_MIN_UPLOAD_INTERVAL_SECONDS=60

# Optional settings
OPENDOTA_TIMEOUT=20
CACHE_TTL_HOURS=24
